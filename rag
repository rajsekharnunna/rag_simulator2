<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>RAG Simulator</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Orbitron:wght@500;700&display=swap" rel="stylesheet">
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --bg: #060816;
  --panel: rgba(17, 25, 40, 0.8);
  --border: rgba(255,255,255,0.08);
  --text: #f9fafb;
  --muted: #9ca3af;
  --accent: #38bdf8;
  --accent2: #8b5cf6;
  --success: #10b981;
  --warning: #f59e0b;
}

body {
  background:
    radial-gradient(circle at top left, rgba(56,189,248,0.12), transparent 25%),
    radial-gradient(circle at bottom right, rgba(139,92,246,0.14), transparent 25%),
    var(--bg);
  color: var(--text);
  font-family: 'Inter', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

canvas {
  position: fixed;
  inset: 0;
  z-index: -1;
}

.container {
  width: min(1400px, 94%);
  margin: 30px auto;
}

.hero {
  text-align: center;
  margin-bottom: 30px;
}

.hero h1 {
  font-family: 'Orbitron', sans-serif;
  font-size: 54px;
  margin-bottom: 16px;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero p {
  max-width: 900px;
  margin: auto;
  line-height: 1.8;
  color: var(--muted);
}

.grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 24px;
}

.panel {
  background: var(--panel);
  backdrop-filter: blur(18px);
  border: 1px solid var(--border);
  border-radius: 28px;
  padding: 24px;
  box-shadow: 0 0 30px rgba(56,189,248,0.12);
}

.sidebar {
  position: sticky;
  top: 20px;
  height: fit-content;
}

.section-title {
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--accent);
  margin-bottom: 18px;
  font-weight: 700;
}

.step {
  padding: 16px;
  border-radius: 18px;
  background: rgba(255,255,255,0.03);
  margin-bottom: 14px;
  border: 1px solid rgba(255,255,255,0.04);
  transition: 0.3s;
}

.step.active {
  border-color: var(--accent);
  transform: translateX(6px);
  box-shadow: 0 0 20px rgba(56,189,248,0.18);
}

.step h3 {
  font-size: 15px;
  margin-bottom: 6px;
}

.step p {
  color: var(--muted);
  font-size: 13px;
  line-height: 1.6;
}

.main {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.input-area textarea {
  width: 100%;
  min-height: 120px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 18px;
  padding: 18px;
  color: white;
  resize: vertical;
  font-size: 15px;
}

button {
  margin-top: 16px;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  color: white;
  border: none;
  padding: 14px 24px;
  border-radius: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: 0.3s;
}

button:hover {
  transform: translateY(-2px);
}

.pipeline {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

.card {
  background: rgba(255,255,255,0.03);
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.06);
  padding: 22px;
  min-height: 220px;
}

.card h2 {
  font-size: 18px;
  margin-bottom: 14px;
  color: var(--accent);
}

.card p,
.card li {
  color: var(--muted);
  line-height: 1.7;
  font-size: 14px;
}

.chunk {
  padding: 12px;
  border-radius: 14px;
  background: rgba(56,189,248,0.08);
  margin-bottom: 10px;
  border: 1px solid rgba(56,189,248,0.12);
}

.embedding {
  font-family: monospace;
  color: #7dd3fc;
  margin-top: 8px;
  font-size: 12px;
  word-break: break-all;
}

.result-box {
  margin-top: 20px;
  padding: 22px;
  border-radius: 22px;
  background: rgba(16,185,129,0.08);
  border: 1px solid rgba(16,185,129,0.2);
}

.highlight {
  color: var(--success);
  font-weight: 600;
}

.flow {
  display: flex;
  align-items: center;
  gap: 12px;
  overflow-x: auto;
  margin-top: 24px;
}

.flow-box {
  min-width: 180px;
  padding: 18px;
  border-radius: 18px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.05);
  text-align: center;
}

.arrow {
  color: var(--accent);
  font-size: 22px;
}

.badge {
  display: inline-block;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(56,189,248,0.12);
  color: var(--accent);
  font-size: 12px;
  margin-top: 10px;
}

@media (max-width: 1000px) {
  .grid {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: relative;
  }

  .hero h1 {
    font-size: 38px;
  }
}
</style>
</head>
<body>
<canvas id="bg"></canvas>

<div class="container">
  <div class="hero">
    <h1>RAG Simulator</h1>
    <p>
      Learn how Retrieval-Augmented Ge
